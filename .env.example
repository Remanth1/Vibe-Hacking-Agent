# Copy this file to .env and fill in the values you want to use.
# All values are optional – the agent runs in fully offline / rule-based mode
# when no LLM provider is configured.

# ── LLM Provider (pick one) ────────────────────────────────────────────────
# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# Ollama (local, no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── App settings ──────────────────────────────────────────────────────────
# Directory where run artefacts are saved (default: ./runs)
# RUNS_DIR=./runs

# Maximum number of seconds a passive scan may run (default: 120)
# PASSIVE_SCAN_TIMEOUT=120

# Maximum number of seconds an active scan may run (default: 600)
# ACTIVE_SCAN_TIMEOUT=600
